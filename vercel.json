{
  "version": 2,
  "builds": [
    {
      "src": "Kalebiber/api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["Kalebiber/*.html", "Kalebiber/data/*.json", "Kalebiber/products.json"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "Kalebiber/api/index.js"
    }
  ]
}
